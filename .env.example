# =====================================================================
# Solgram Control - variables de entorno
# Copia este archivo a .env (o .env.local) y rellénalo.
# =====================================================================

# --- Gemini ---------------------------------------------------------
# API key para el endpoint /api/chat (Solgramia).
GEMINI_API_KEY=""

# --- Servidor -------------------------------------------------------
# Puerto en el que arranca el server Express. (default: 3000)
PORT=3000

# URL pública de la app (usada por Cloud Run / OAuth callbacks, etc.)
APP_URL=""

# --- Firebase Admin SDK ---------------------------------------------
# El backend NECESITA credenciales de Firebase Admin para verificar el
# ID Token enviado por el cliente al /api/chat. Elige UNA opción:
#
# Opción A) Ruta a un archivo JSON de service-account
GOOGLE_APPLICATION_CREDENTIALS=""
#
# Opción B) JSON crudo de service-account, en una sola línea (escapado)
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"..."}'

# --- Bootstrap del primer admin (sólo para scripts/bootstrap-admin.cjs) -----
# Email + password de un usuario ya existente en Firebase Auth que
# quieres marcar como administrador. El script solo crea/borra el doc
# /admins/{uid}; la cuenta debe existir previamente en Firebase Auth.
BOOTSTRAP_ADMIN_EMAIL=""
BOOTSTRAP_ADMIN_UID=""


# =====================================================================
# AWS / Amplify (Fase de migracion)
# Estos valores se generan automaticamente al correr `npx ampx sandbox`
# y quedan en `amplify_outputs.json` (gitignored). NO los commitees.
# Solo defines manualmente los de abajo.
# =====================================================================

# Region AWS donde se desplegara el backend.
AWS_REGION="us-east-1"

# (Opcional) Profile de credenciales AWS local.
AWS_PROFILE="default"
