    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.0.1",
    "firebase-functions": "^6.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "typescript": "~5.8.2"
  }
}
